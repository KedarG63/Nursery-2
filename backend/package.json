{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for Nursery Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:up": "node-pg-migrate up -m migrations --config-file config/migrations.js",
    "migrate:docker": "node migrate.js",
    "migrate:down": "node-pg-migrate down -m migrations --config-file config/migrations.js",
    "migrate:create": "node-pg-migrate create -m migrations --config-file config/migrations.js",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPattern=unit",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPattern=integration",
    "test:verbose": "cross-env NODE_ENV=test jest --verbose",
    "test:debug": "cross-env NODE_ENV=test node --inspect-brk node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@google-cloud/monitoring": "^4.0.0",
    "@google-cloud/storage": "^7.12.0",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^8.1.0",
    "razorpay": "^2.9.2",
    "node-pg-migrate": "^6.2.2",
    "sharp": "^0.34.4",
    "uuid": "^13.0.0",
    "validator": "^13.15.15",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4"
  }
}
