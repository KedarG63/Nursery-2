# Test Environment Configuration
# Phase 19 - Testing Framework

NODE_ENV=test

# Database Configuration (Test Database)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nursery_test_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_STATEMENT_TIMEOUT=30000

# JWT Configuration
JWT_SECRET=test-jwt-secret-key-for-testing-only
JWT_EXPIRY=1h
JWT_REFRESH_SECRET=test-refresh-secret-key-for-testing-only
JWT_REFRESH_EXPIRY=7d

# Redis Configuration (Optional for tests)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# External Services - MOCK MODE
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=https://mock-whatsapp-api.com
WHATSAPP_API_KEY=mock-api-key

# Payment Gateway - TEST MODE
PAYMENT_GATEWAY_MODE=test
RAZORPAY_KEY_ID=test_key_id
RAZORPAY_KEY_SECRET=test_key_secret

# GPS Tracking - DISABLED
GPS_TRACKING_ENABLED=false
GPS_PROVIDER=mock

# Email Service - DISABLED
EMAIL_ENABLED=false
EMAIL_SERVICE=mock

# File Storage - LOCAL MODE
STORAGE_TYPE=local
UPLOAD_DIR=./tests/uploads

# Rate Limiting
RATE_LIMIT_ENABLED=true
ADMIN_WHITELIST=127.0.0.1,::1

# Security
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
SESSION_SECRET=test-session-secret
HTTPS_ENABLED=false

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# Testing Configuration
COVERAGE_THRESHOLD=70
TEST_TIMEOUT=10000
MOCK_EXTERNAL_SERVICES=true

# Logging
LOG_LEVEL=error
LOG_DIR=./tests/logs
