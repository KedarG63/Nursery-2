# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nursery_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_MAX_CONNECTIONS=20
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/nursery_db

# JWT Configuration
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# AWS S3 Configuration (for QR Code Storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=nursery-qr-codes

# Payment Gateway Configuration
PAYMENT_PROVIDER=mock              # Options: mock, razorpay
PAYMENT_CURRENCY=INR

# Razorpay Credentials (only needed if PAYMENT_PROVIDER=razorpay)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_key
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Delivery Configuration
DEFAULT_WAREHOUSE_LAT=28.7041
DEFAULT_WAREHOUSE_LNG=77.1025
AVERAGE_DELIVERY_SPEED_KMH=30
GPS_UPDATE_INTERVAL_SECONDS=30
GPS_PROVIDER=mock                  # Options: mock, loconav, fleetx

# Mock GPS Settings (for development)
MOCK_GPS_ENABLED=true
MOCK_GPS_SIMULATION_SPEED=1        # 1x real-time

# Real GPS Provider (for production - optional)
LOCONAV_API_KEY=your_loconav_key
LOCONAV_API_URL=https://api.loconav.com
LOCONAV_WEBHOOK_SECRET=your_loconav_webhook_secret

FLEETX_API_KEY=your_fleetx_key
FLEETX_API_URL=https://api.fleetx.io
FLEETX_WEBHOOK_SECRET=your_fleetx_webhook_secret

# WhatsApp Configuration
WHATSAPP_PROVIDER=mock                    # Options: mock, meta, twilio, gupshup
MOCK_WHATSAPP_ENABLED=true
MOCK_WHATSAPP_DELAY=1000                  # Simulate send delay in ms
MOCK_FAILURE_RATE=0.0                     # Simulate failure rate (0.0 = 0%, 0.1 = 10%)

# Meta WhatsApp Business API (set WHATSAPP_PROVIDER=meta to activate)
# Get from: Meta Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_system_user_token_here
WHATSAPP_API_VERSION=v21.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_random_webhook_secret_here

# Twilio WhatsApp (for production - optional)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Gupshup WhatsApp (for production - optional)
GUPSHUP_API_KEY=your_api_key
GUPSHUP_APP_NAME=your_app_name
GUPSHUP_SOURCE_NUMBER=your_source_number

# Notification Settings
NOTIFICATION_ENABLED=true
SEND_ORDER_CONFIRMATIONS=true
SEND_DELIVERY_UPDATES=true
SEND_PAYMENT_REMINDERS=true

# Phase 17: Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Phase 17: Winston Logging
LOG_LEVEL=info

# Phase 17: AWS S3 File Storage (updated)
AWS_S3_BUCKET_NAME=nursery-uploads

# Phase 17: Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Phase 18: Rate Limiting (Issue #86)
ADMIN_WHITELIST=127.0.0.1,::1
RATE_LIMIT_ENABLED=true

# Phase 18: Security (Issue #88)
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
SESSION_SECRET=your-super-secret-session-key-change-in-production
HTTPS_ENABLED=false

# Phase 18: Database Performance (Issue #89)
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000
DB_STATEMENT_TIMEOUT=30000
DB_QUERY_TIMEOUT=30000

# Phase 18: Response Compression (Issue #90)
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024
